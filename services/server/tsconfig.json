{
  "extends": "ts-node/node16/tsconfig.json",
  "compilerOptions": {
    "target": "es2020",
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./*"],
      "~/*": ["./public/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
